{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "services": [
    {
      "name": "CivicView",
      "startCommand": "gunicorn civicview_project.wsgi --bind 0.0.0.0:8000",
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 5
    },
    {
      "name": "celery",
      "startCommand": "celery -A civicview_project worker -l info",
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 5
    }
  ]
}